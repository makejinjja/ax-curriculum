# ── Required ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=60
DEMO_USER=admin
DEMO_PASSWORD=password

# ── Optional ──────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...        # enables web_search tool
OPENAI_MODEL=gpt-4o-mini       # or gpt-4o for higher quality

# ── Path overrides (Docker sets these automatically) ──────────
# RAG_DATA_DIR=/app/data
# RAG_CACHE_FILE=/app/data/.index_cache/rag_index.json

# ── Streamlit Cloud secrets (set in dashboard, not here) ──────
# BACKEND_URL=https://your-backend-domain.com
